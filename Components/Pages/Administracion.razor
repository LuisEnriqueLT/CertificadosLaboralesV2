    // ── Usuario CRUD ──────────────────────────────────────────────────
    private string _usuarioEmail = "", _usuarioPassword = "", _usuarioRol = "Admin";
    private ApplicationUser? _usuarioEditing;

    private void OpenAddUsuario()
    {
        _usuarioEmail = "";
        _usuarioPassword = "";
        _usuarioRol = "Admin";
        _usuarioEditing = null;
        _modalTitle = "Agregar usuario";
        _modalSaveAction = SaveUsuario;
        SetUsuarioModalContent();
        _showModal = true;
    }

    private async Task OpenEditUsuario(ApplicationUser u)
    {
        _usuarioEmail = u.Email ?? "";
        _usuarioPassword = "";
        var roles = await UserMgr.GetRolesAsync(u);
        _usuarioRol = roles.FirstOrDefault() ?? "Admin";
        _usuarioEditing = u;
        _modalTitle = "Editar usuario";
        _modalSaveAction = SaveUsuario;
        SetUsuarioModalContent();
        _showModal = true;
    }

    private void SetUsuarioModalContent()
    {
        _modalContent = @<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div style="grid-column:1/-1;display:flex;flex-direction:column;gap:6px;">
                <label style="font-size:12.5px;font-weight:500;color:#475569;">Correo electrónico</label>
                <input @bind="_usuarioEmail" type="email" placeholder="correo@dominio.com" style="@InputStyle" readonly="@(_usuarioEditing != null)" />
            </div>
            <div style="display:flex;flex-direction:column;gap:6px;">
                <label style="font-size:12.5px;font-weight:500;color:#475569;">Rol</label>
                <select @bind="_usuarioRol" style="@SelectStyle">
                    @foreach (var r in _roles)
                    {
                        <option value="@r.Name">@r.Name</option>
                    }
                </select>
            </div>
            <div style="display:flex;flex-direction:column;gap:6px;">
                <label style="font-size:12.5px;font-weight:500;color:#475569;">@(_usuarioEditing != null ? "Nueva contraseña (opcional)" : "Contraseña temporal")</label>
                <input @bind="_usuarioPassword" type="password" placeholder="Mínimo 6 caracteres" style="@InputStyle" />
            </div>
        </div>;
    }

    private async Task SaveUsuario()
    {
        if (_usuarioEditing == null)
        {
            if (string.IsNullOrWhiteSpace(_usuarioEmail) || string.IsNullOrWhiteSpace(_usuarioPassword))
            {
                Snackbar.Add("Complete todos los campos.", Severity.Warning);
                return;
            }
            var pais = new Pais { Id = 1 }; // default
            var user = new ApplicationUser { UserName = _usuarioEmail, Email = _usuarioEmail, PaisId = 1 };
            var result = await UserMgr.CreateAsync(user, _usuarioPassword);
            if (!result.Succeeded)
            {
                Snackbar.Add(string.Join(", ", result.Errors.Select(e => e.Description)), Severity.Error);
                return;
            }
            await UserMgr.AddToRoleAsync(user, _usuarioRol);
        }
        else
        {
            var currentRoles = await UserMgr.GetRolesAsync(_usuarioEditing);
            await UserMgr.RemoveFromRolesAsync(_usuarioEditing, currentRoles);
            await UserMgr.AddToRoleAsync(_usuarioEditing, _usuarioRol);
            if (!string.IsNullOrWhiteSpace(_usuarioPassword))
            {
                var token = await UserMgr.GeneratePasswordResetTokenAsync(_usuarioEditing);
                await UserMgr.ResetPasswordAsync(_usuarioEditing, token, _usuarioPassword);
            }
        }
        _users = UserMgr.Users.ToList();
        Snackbar.Add("Usuario guardado.", Severity.Success);
        _showModal = false;
    }

    private async Task DeleteUsuario(string id)
    {
        var user = await UserMgr.FindByIdAsync(id);
        if (user != null) await UserMgr.DeleteAsync(user);
        _users = UserMgr.Users.ToList();
        Snackbar.Add("Usuario eliminado.", Severity.Success);
    }

