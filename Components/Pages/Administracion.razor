    private static string GetInputTypeForDato(TipoDatoVariable tipo) => tipo switch
    {
        TipoDatoVariable.Numero => "number",
        TipoDatoVariable.Fecha => "date",
        _ => "text"
    };

    private async Task SaveEmpleado()
