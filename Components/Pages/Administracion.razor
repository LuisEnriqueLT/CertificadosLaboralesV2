    private void OnPlaceholderFieldChange(ChangeEventArgs e)
    {
        _placeholderFieldSelection = e.Value?.ToString() ?? "";
        if (_placeholderFieldSelection.StartsWith("F:"))
        {
            _placeholderForm.CampoFijo = _placeholderFieldSelection[2..];
            _placeholderForm.DatoVariableId = null;
        }
        else if (_placeholderFieldSelection.StartsWith("D:"))
        {
            _placeholderForm.CampoFijo = null;
            _placeholderForm.DatoVariableId = int.TryParse(_placeholderFieldSelection[2..], out var id) ? id : null;
        }
        else
        {
            _placeholderForm.CampoFijo = null;
            _placeholderForm.DatoVariableId = null;
        }
    }

    private void SetPlaceholderModalContent()
    {
        _modalContent = @<div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
            <div style="display:flex;flex-direction:column;gap:6px;">
                <label style="font-size:12.5px;font-weight:500;color:#475569;">Placeholder</label>
                <input @bind="_placeholderForm.PlaceholderTexto" placeholder="Ej. NombreEmpleado" style="@InputStyle" />
            </div>
            <div style="display:flex;flex-direction:column;gap:6px;">
                <label style="font-size:12.5px;font-weight:500;color:#475569;">Campo de datos</label>
                <select value="@_placeholderFieldSelection" @onchange="OnPlaceholderFieldChange" style="@SelectStyle">
                    <option value="">— Seleccione —</option>
                    <optgroup label="Campos fijos">
                        @foreach (var kv in CamposFijosEmpleado.Campos)
                        {
                            <option value="@($"F:{kv.Key}")">@kv.Value</option>
                        }
                    </optgroup>
                    <optgroup label="Campos dinámicos">
                        @foreach (var d in _datosVariables)
                        {
                            <option value="@($"D:{d.Id}")">@d.NombreCampo</option>
                        }
                    </optgroup>
                </select>
            </div>
            <div style="grid-column:1/-1;display:flex;flex-direction:column;gap:6px;">
                <label style="font-size:12.5px;font-weight:500;color:#475569;">Descripción</label>
                <input @bind="_placeholderForm.Texto" placeholder="Qué dato reemplaza" style="@InputStyle" />
            </div>
        </div>;
    }

    private async Task SavePlaceholder()
    {
        if (_placeholderForm.DatoVariableId == null && string.IsNullOrWhiteSpace(_placeholderForm.CampoFijo))
        {
            Snackbar.Add("Selecciona un campo.", Severity.Warning);
            return;
        }

        if (_placeholderForm.Id == 0)
            await PlaceholderSvc.AgregarPlaceholderAsync(_placeholderForm);
        else
            await PlaceholderSvc.ActualizarPlaceholderAsync(_placeholderForm);
        _placeholders = await PlaceholderSvc.ObtenerTodosLosPlaceholdersAsync();
        Snackbar.Add("Placeholder guardado.", Severity.Success);
        _showModal = false;
    }

    private async Task DeletePlaceholder(int id)
    {
        await PlaceholderSvc.EliminarPlaceholderAsync(id);
        _placeholders = await PlaceholderSvc.ObtenerTodosLosPlaceholdersAsync();
        Snackbar.Add("Placeholder eliminado.", Severity.Success);
    }

    // ── Historial ────────────────────────────────────────────────────
    private async Task DescargarHistorial(Historial h)
    {
        await JS.InvokeVoidAsync("downloadFile",
            $"historial_{h.Id}_{h.FechaCreacion:yyyyMMdd}.pdf",
            "application/pdf", h.Contenido);
    }

    // ── Excel Import ─────────────────────────────────────────────────
    private void OnExcelSelected(InputFileChangeEventArgs e)
    {
        _excelFile = e.File;
        _excelFileName = e.File.Name;
        _excelResultado = "";
    }

    private async Task ProcesarExcel()
    {
        if (_excelFile == null) return;
        _procesandoExcel = true;
        _excelResultado = "";
        try
        {
            await ExcelUploadSvc.GuardarExcelAsync(_excelFile, sobreEscribir: true);
            var firmantes = await ExcelSvc.ActualizarFirmantesExcel();
            var empresas = await ExcelSvc.ActualizarEmpresasExcel();
            var empleados = await ExcelSvc.ActualizarEmpleadosExcel();
            int nuevasE = empresas[0].Count, modE = empresas[1].Count;
            int nuevosEmp = empleados[0].Count, modEmp = empleados[1].Count;
            int nuevasF = firmantes[0].Count, modF = firmantes[1].Count;
            _excelResultado = $"Empresas: {nuevasE} nuevas, {modE} actualizadas. " +
                              $"Empleados: {nuevosEmp} nuevos, {modEmp} actualizados. " +
                              $"Firmantes: {nuevasF} nuevos, {modF} actualizados.";
            Snackbar.Add("Excel procesado correctamente.", Severity.Success);
        }
        catch (Exception ex)
        {
            _excelResultado = $"Error: {ex.Message}";
            Snackbar.Add("Error al procesar el Excel.", Severity.Error);
        }
        finally
        {
            _procesandoExcel = false;
        }
    }

    // ── Helpers ──────────────────────────────────────────────────────
    private static string GetImageMimeType(byte[] bytes)
    {
        if (bytes.Length >= 4 && bytes[0] == 0x89 && bytes[1] == 0x50) return "image/png";
        if (bytes.Length >= 2 && bytes[0] == 0xFF && bytes[1] == 0xD8) return "image/jpeg";
        return "image/png";
    }

    private static string InputStyle =>
        "height:40px;border:1px solid #cbd5e1;border-radius:4px;padding:0 12px;font-size:14px;font-family:Roboto,sans-serif;color:#1e293b;outline:none;width:100%;";
    private static string SelectStyle =>
        "appearance:none;-webkit-appearance:none;height:40px;border:1px solid #cbd5e1;border-radius:4px;padding:0 12px;font-size:14px;font-family:Roboto,sans-serif;color:#1e293b;background:#ffffff;outline:none;width:100%;cursor:pointer;";
}
