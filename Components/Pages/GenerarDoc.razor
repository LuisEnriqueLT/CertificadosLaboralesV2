@page "/generar-doc"
@rendermode InteractiveServer
@attribute [Authorize]
@inject EmpresaService EmpresaSvc
@inject EmpleadoService EmpleadoSvc
@inject PlantillaService PlantillaSvc
@inject CreateDocService DocSvc
@inject EmailService EmailSvc
@inject AuthenticationStateProvider AuthState
@inject IJSRuntime JS
@inject ISnackbar Snackbar

<PageTitle>Generar documentos — Uiglobal</PageTitle>

<div style="flex:1;width:100%;max-width:1560px;margin:0 auto;padding:28px 32px 40px;">

    <!-- Header -->
    <div style="margin-bottom:22px;">
        <div style="font-size:22px;font-weight:600;letter-spacing:-0.2px;color:#0f172a;">Generar documentos</div>
        <div style="font-size:13.5px;color:#64748b;margin-top:4px;">Cree, descargue y envíe certificados laborales a partir de plantillas</div>
    </div>

    <div style="display:flex;gap:24px;align-items:flex-start;">

        <!-- Form card -->
        <div style="width:400px;flex-shrink:0;background:#ffffff;border:1px solid #e2e8f0;border-radius:8px;box-shadow:0 1px 2px rgba(15,23,42,0.05);padding:26px 28px;display:flex;flex-direction:column;gap:20px;">

            <div>
                <div style="font-size:16px;font-weight:600;color:#0f172a;">Datos del certificado</div>
                <div style="font-size:13px;color:#64748b;margin-top:3px;">Seleccione la información del documento</div>
            </div>

            <!-- Empresa selector -->
            <div style="display:flex;flex-direction:column;gap:6px;">
                <label style="font-size:12.5px;font-weight:500;color:#475569;letter-spacing:0.2px;">Empresa</label>
                <div style="position:relative;">
                    <select @onchange="OnEmpresaChange" style="appearance:none;-webkit-appearance:none;width:100%;height:42px;border:1px solid #cbd5e1;border-radius:4px;padding:0 38px 0 12px;font-size:14px;font-family:Roboto,sans-serif;color:#1e293b;background:#ffffff;cursor:pointer;outline:none;text-overflow:ellipsis;"
                            onfocus="this.style.borderColor='#F97316';this.style.boxShadow='0 0 0 3px rgba(249,115,22,0.12)';"
                            onblur="this.style.borderColor='#cbd5e1';this.style.boxShadow='none';">
                        <option value="0">— Seleccione una empresa —</option>
                        @foreach (var e in _empresas)
                        {
                            <option value="@e.Id">@e.Nombre</option>
                        }
                    </select>
                    <span class="icon" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);color:#64748b;pointer-events:none;">expand_more</span>
                </div>
            </div>

            <!-- Empleado selector -->
            <div style="display:flex;flex-direction:column;gap:6px;">
                <label style="font-size:12.5px;font-weight:500;color:#475569;letter-spacing:0.2px;">Empleado</label>
                <div style="position:relative;">
                    <select @onchange="OnEmpleadoChange" disabled="@(_selectedEmpresaId == 0)"
                            style="appearance:none;-webkit-appearance:none;width:100%;height:42px;border:1px solid #cbd5e1;border-radius:4px;padding:0 38px 0 12px;font-size:14px;font-family:Roboto,sans-serif;color:#1e293b;background:#ffffff;cursor:pointer;outline:none;text-overflow:ellipsis;opacity:@(_selectedEmpresaId == 0 ? "0.5" : "1");"
                            onfocus="this.style.borderColor='#F97316';this.style.boxShadow='0 0 0 3px rgba(249,115,22,0.12)';"
                            onblur="this.style.borderColor='#cbd5e1';this.style.boxShadow='none';">
                        <option value="0">— Seleccione un empleado —</option>
                        @foreach (var e in _empleados)
                        {
                            <option value="@e.Id">@e.NombreCompleto</option>
                        }
                    </select>
                    <span class="icon" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);color:#64748b;pointer-events:none;">expand_more</span>
                </div>
            </div>

            <!-- Plantilla selector -->
            <div style="display:flex;flex-direction:column;gap:6px;">
                <label style="font-size:12.5px;font-weight:500;color:#475569;letter-spacing:0.2px;">Plantilla</label>
                <div style="position:relative;">
                    <select @onchange="OnPlantillaChange" disabled="@(_selectedEmpresaId == 0)"
                            style="appearance:none;-webkit-appearance:none;width:100%;height:42px;border:1px solid #cbd5e1;border-radius:4px;padding:0 38px 0 12px;font-size:14px;font-family:Roboto,sans-serif;color:#1e293b;background:#ffffff;cursor:pointer;outline:none;opacity:@(_selectedEmpresaId == 0 ? "0.5" : "1");"
                            onfocus="this.style.borderColor='#F97316';this.style.boxShadow='0 0 0 3px rgba(249,115,22,0.12)';"
                            onblur="this.style.borderColor='#cbd5e1';this.style.boxShadow='none';">
                        <option value="0">— Seleccione una plantilla —</option>
                        @foreach (var p in _plantillas)
                        {
                            <option value="@p.Id">@p.NombrePlantilla</option>
                        }
                    </select>
                    <span class="icon" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);color:#64748b;pointer-events:none;">expand_more</span>
                </div>
            </div>

            <!-- Sin sello -->
            <label style="display:flex;align-items:flex-start;gap:10px;cursor:pointer;padding:2px 0;">
                <input type="checkbox" @bind="_sinSello" style="width:16px;height:16px;accent-color:#F97316;cursor:pointer;margin:2px 0 0;" />
                <span>
                    <span style="display:block;font-size:14px;color:#1e293b;">Generar sin sello</span>
                    <span style="display:block;font-size:12.5px;color:#94a3b8;margin-top:2px;">Omite el logo y firma del representante legal</span>
                </span>
            </label>

            <div style="height:1px;background:#e2e8f0;"></div>

            <!-- Enviar por correo -->
            <div style="display:flex;flex-direction:column;gap:6px;">
                <label style="font-size:12.5px;font-weight:500;color:#475569;letter-spacing:0.2px;">Enviar por correo</label>
                <div style="display:flex;gap:10px;">
                    <input @bind="_emailDestino" type="email" placeholder="correo@dominio.com"
                           style="flex:1;min-width:0;height:42px;border:1px solid #cbd5e1;border-radius:4px;padding:0 12px;font-size:14px;font-family:Roboto,sans-serif;color:#1e293b;outline:none;"
                           onfocus="this.style.borderColor='#F97316';this.style.boxShadow='0 0 0 3px rgba(249,115,22,0.12)';"
                           onblur="this.style.borderColor='#cbd5e1';this.style.boxShadow='none';" />
                    <button @onclick="HandleEnviarCorreo" disabled="@(!CanGenerate || _sendingEmail)"
                            style="height:42px;padding:0 16px;border:1px solid rgba(249,115,22,0.55);border-radius:4px;background:transparent;color:#ea580c;font-family:Roboto,sans-serif;font-size:13px;font-weight:500;letter-spacing:0.5px;text-transform:uppercase;cursor:pointer;display:flex;align-items:center;gap:6px;opacity:@(!CanGenerate ? "0.5" : "1");">
                        <span class="icon" style="font-size:18px;">mail</span>
                        Enviar
                    </button>
                </div>
            </div>

            <!-- Action buttons -->
            <div style="display:flex;gap:12px;margin-top:4px;">
                <button @onclick="HandleDescargarPdf" disabled="@(!CanGenerate || _generatingPdf)"
                        style="flex:1;height:44px;border:none;border-radius:4px;background:#F97316;color:#ffffff;font-family:Roboto,sans-serif;font-size:13.5px;font-weight:500;letter-spacing:0.5px;text-transform:uppercase;cursor:pointer;box-shadow:0 2px 6px rgba(249,115,22,0.35);display:flex;align-items:center;justify-content:center;gap:8px;opacity:@(!CanGenerate ? "0.5" : "1");">
                    @if (_generatingPdf)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" Color="Color.Inherit" />
                    }
                    else
                    {
                        <span class="icon" style="font-size:19px;">download</span>
                    }
                    Descargar PDF
                </button>
                <button @onclick="HandleDescargarDocx" disabled="@(!CanGenerate || _generatingDocx)"
                        style="height:44px;padding:0 18px;border:1px solid rgba(249,115,22,0.55);border-radius:4px;background:transparent;color:#ea580c;font-family:Roboto,sans-serif;font-size:13.5px;font-weight:500;letter-spacing:0.5px;text-transform:uppercase;cursor:pointer;display:flex;align-items:center;gap:8px;opacity:@(!CanGenerate ? "0.5" : "1");">
                    @if (_generatingDocx)
                    {
                        <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                    }
                    else
                    {
                        <span class="icon" style="font-size:19px;">description</span>
                    }
                    DOCX
                </button>
            </div>
        </div>

        <!-- Preview card -->
        <div style="flex:1;min-width:0;background:#ffffff;border:1px solid #e2e8f0;border-radius:8px;box-shadow:0 1px 2px rgba(15,23,42,0.05);display:flex;flex-direction:column;overflow:hidden;min-height:600px;">
            <div style="padding:14px 24px;border-bottom:1px solid #e2e8f0;display:flex;align-items:center;justify-content:space-between;">
                <div style="display:flex;align-items:center;gap:12px;">
                    <span style="font-size:15px;font-weight:600;color:#0f172a;">Vista previa</span>
                    @if (_selectedPlantilla != null)
                    {
                        <span style="font-size:12px;font-weight:500;color:#475569;background:#f1f5f9;border-radius:999px;padding:3px 12px;">@_selectedPlantilla.NombrePlantilla</span>
                    }
                </div>
                @if (_selectedEmpleado != null && _selectedEmpresa != null)
                {
                    <span style="font-size:12.5px;color:#94a3b8;">@_selectedEmpleado.NombreCompleto · @_selectedEmpresa.Nombre</span>
                }
            </div>
            <div style="flex:1;background:#e9eef5;padding:36px 32px;display:flex;justify-content:center;overflow:auto;">
                @if (_loadingPreview)
                {
                    <div style="display:flex;align-items:center;justify-content:center;width:100%;">
                        <MudProgressCircular Color="Color.Primary" Indeterminate="true" />
                    </div>
                }
                else if (string.IsNullOrEmpty(_previewHtml))
                {
                    <div style="display:flex;flex-direction:column;align-items:center;justify-content:center;color:#94a3b8;gap:12px;width:100%;">
                        <span class="icon" style="font-size:48px;">description</span>
                        <span style="font-size:14px;">Seleccione empresa, empleado y plantilla para ver la vista previa</span>
                    </div>
                }
                else
                {
                    <div class="paper-doc">
                        @((MarkupString)_previewHtml)
                    </div>
                }
            </div>
        </div>
    </div>
</div>

@code {
    private List<Empresa> _empresas = [];
    private List<Empleado> _empleados = [];
    private List<PlantillaHtml> _plantillas = [];

    private int _selectedEmpresaId = 0;
    private int _selectedEmpleadoId = 0;
    private int _selectedPlantillaId = 0;
    private bool _sinSello = false;
    private string _emailDestino = "";

    private Empresa? _selectedEmpresa;
    private Empleado? _selectedEmpleado;
    private PlantillaHtml? _selectedPlantilla;

    private string _previewHtml = "";
    private bool _loadingPreview = false;
    private bool _generatingPdf = false;
    private bool _generatingDocx = false;
    private bool _sendingEmail = false;

    private bool CanGenerate => _selectedEmpresaId > 0 && _selectedEmpleadoId > 0 && _selectedPlantillaId > 0;

    private int _currentUserId = 0;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthState.GetAuthenticationStateAsync();
        var user = auth.User;
        var isSuperAdmin = user.IsInRole("SuperAdmin");
        var isAdmin = user.IsInRole("Admin");

        if (isSuperAdmin || isAdmin)
        {
            _empresas = await EmpresaSvc.ObtenerEmpresasAsync();
        }
        else
        {
            var userId = user.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value ?? "";
            var empresasRaw = await EmpresaSvc.ObtenerEmpresasPorUsuarioAsync(userId);
            _empresas = empresasRaw.OfType<Empresa>().ToList();
        }
    }

    private async Task OnEmpresaChange(ChangeEventArgs e)
    {
        _selectedEmpresaId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        _selectedEmpleadoId = 0;
        _selectedPlantillaId = 0;
        _previewHtml = "";
        _selectedEmpresa = _empresas.FirstOrDefault(x => x.Id == _selectedEmpresaId);
        _selectedEmpleado = null;
        _selectedPlantilla = null;

        if (_selectedEmpresaId > 0)
        {
            _empleados = await EmpleadoSvc.ObtenerEmpleadosPorEmpresaIdAsync(_selectedEmpresaId);
            _plantillas = await PlantillaSvc.ObtenerPlantillasPorEmpresaIdAsync(_selectedEmpresaId);
        }
        else
        {
            _empleados = [];
            _plantillas = [];
        }
    }

    private async Task OnEmpleadoChange(ChangeEventArgs e)
    {
        _selectedEmpleadoId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        _selectedEmpleado = _empleados.FirstOrDefault(x => x.Id == _selectedEmpleadoId);
        await ActualizarPreview();
    }

    private async Task OnPlantillaChange(ChangeEventArgs e)
    {
        _selectedPlantillaId = int.TryParse(e.Value?.ToString(), out var id) ? id : 0;
        _selectedPlantilla = _plantillas.FirstOrDefault(x => x.Id == _selectedPlantillaId);
        await ActualizarPreview();
    }

    private async Task ActualizarPreview()
    {
        if (!CanGenerate) { _previewHtml = ""; return; }

        _loadingPreview = true;
        StateHasChanged();
        try
        {
            _previewHtml = await DocSvc.ObtenerHtmlPreviewAsync(
                _selectedPlantillaId, _selectedEmpresaId, _selectedEmpleadoId, _sinSello);
        }
        catch
        {
            _previewHtml = "";
        }
        finally
        {
            _loadingPreview = false;
        }
    }

    private async Task HandleDescargarPdf()
    {
        if (!CanGenerate) return;
        _generatingPdf = true;
        try
        {
            var (bytes, nombre) = await DocSvc.GenerarDocumentoPdfAsync(
                _selectedPlantillaId, _selectedEmpresaId, _selectedEmpleadoId, _currentUserId, _sinSello);
            await JS.InvokeVoidAsync("downloadFile", nombre, "application/pdf", bytes);
            Snackbar.Add("PDF descargado correctamente.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al generar PDF: {ex.Message}", Severity.Error);
        }
        finally
        {
            _generatingPdf = false;
        }
    }

    private async Task HandleDescargarDocx()
    {
        if (!CanGenerate) return;
        _generatingDocx = true;
        try
        {
            var (bytes, nombre) = await DocSvc.GenerarDocumentoDocxAsync(
                _selectedPlantillaId, _selectedEmpresaId, _selectedEmpleadoId);
            await JS.InvokeVoidAsync("downloadFile", nombre, "application/vnd.openxmlformats-officedocument.wordprocessingml.document", bytes);
            Snackbar.Add("DOCX descargado correctamente.", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error al generar DOCX: {ex.Message}", Severity.Error);
        }
        finally
        {
            _generatingDocx = false;
        }
    }

    private async Task HandleEnviarCorreo()
    {
        if (!CanGenerate || string.IsNullOrWhiteSpace(_emailDestino)) return;
        _sendingEmail = true;
        try
        {
            var (bytes, nombre) = await DocSvc.GenerarDocumentoPdfAsync(
                _selectedPlantillaId, _selectedEmpresaId, _selectedEmpleadoId, _currentUserId, _sinSello);
            var ok = await EmailSvc.EnviarCorreoAsync(_emailDestino, "Certificado laboral", "Adjunto su certificado laboral.", bytes, nombre);
            Snackbar.Add(ok ? "Correo enviado correctamente." : "No se pudo enviar el correo.", ok ? Severity.Success : Severity.Error);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error: {ex.Message}", Severity.Error);
        }
        finally
        {
            _sendingEmail = false;
        }
    }
}
